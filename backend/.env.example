# Open Campus backend configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All vars are prefixed OC_ (see app/config.py).
#
# The server is STATELESS — no database, no encryption-at-rest, because we store
# nothing. The only secret is the JWT signing key.

# --- Our JWT signing secret (NOT a UCAM credential) ---
# REQUIRED in production. Generate a fresh one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app REFUSES to start in non-debug mode with the placeholder or a short key.
OC_SESSION_SECRET=change-me-to-a-long-random-string
OC_SESSION_TTL_MINUTES=60

# --- Behavior ---
OC_PER_USER_MIN_INTERVAL_SECONDS=1.0

# --- Debug ---
# Keep FALSE for any shared/beta/production deployment. When true:
#   * the production-safety gate is bypassed (placeholder secret allowed)
#   * logging drops to DEBUG level
# Set to true ONLY on your own local machine.
OC_DEBUG=false

# --- CORS (JSON list) ---
# A native app needs none. For a hosted web build, list the exact origin(s) the
# web app is served from. NEVER use "*" (the safety gate blocks it in production).
# OC_CORS_ORIGINS=["https://opencampus.example"]
